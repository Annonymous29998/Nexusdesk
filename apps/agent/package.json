{
  "name": "@nexusdesk/agent",
  "version": "0.1.0",
  "description": "NexusDesk installable remote agent — background service that enrolls a device, streams desktop frames, and executes remote commands",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "nexusdesk-agent": "./dist/main.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@nexusdesk/shared": "*",
    "@nexusdesk/types": "*",
    "@nexusdesk/utils": "*",
    "koffi": "^2.9.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "screenshot-desktop": "^1.15.1",
    "systeminformation": "^5.25.11",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ]
}
