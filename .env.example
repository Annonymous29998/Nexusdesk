# =============================================================================
# NexusDesk — Environment Variables
# Copy to `.env` and fill in real values. Never commit secrets.
# =============================================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Application URLs ---
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4000
CDN_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://nexusdesk:nexusdesk@localhost:5432/nexusdesk?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=nexusdesk:

# --- Authentication / JWT ---
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=nexusdesk
JWT_AUDIENCE=nexusdesk-api

# --- Session / cookies ---
SESSION_SECRET=change-me-session-secret-min-32-chars-long!
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost
COOKIE_SAME_SITE=lax

# --- Encryption (AES-256-GCM) — 32-byte key, base64-encoded ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Agent / device registration ---
AGENT_ENROLLMENT_SECRET=change-me-agent-enrollment-secret!!
AGENT_HEARTBEAT_INTERVAL_MS=30000
AGENT_OFFLINE_THRESHOLD_MS=90000

# --- WebRTC / TURN / STUN ---
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URLS=turn:turn.example.com:3478
TURN_USERNAME=
TURN_CREDENTIAL=
TURN_CREDENTIAL_TTL=86400

# --- Email (SMTP) ---
# Use SMTP_HOST=console for local/dev without Mailhog (logs emails to console)
SMTP_HOST=console
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NexusDesk <noreply@nexusdesk.local>

# --- Object storage (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nexusdesk
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_AUTH_MAX=20

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Feature flags ---
FEATURE_VIEW_ONLY_DEFAULT=false
FEATURE_RECORDING_ENABLED=true
FEATURE_AUDIT_RETENTION_DAYS=90

# --- Internal service tokens ---
INTERNAL_API_TOKEN=change-me-internal-api-token-min-32-chars!
SERVICE_NAME=nexusdesk

# --- Supabase (optional) ---
# Set DATABASE_URL to your Supabase Postgres URI (Direct, port 5432).
# See docs/SUPABASE.md or run: npm run supabase:configure

# --- Dashboard (Vite) ---
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
VITE_DEMO_MODE=auto

# --- Windows agent package path (optional override) ---
AGENT_PACKAGE_PATH=
