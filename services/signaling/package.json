{
  "name": "@nexusdesk/signaling",
  "version": "0.1.0",
  "description": "Standalone WebRTC signaling microservice for NexusDesk (room-based, JWT-authenticated)",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "nexusdesk-signaling": "./dist/main.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@nexusdesk/shared": "*",
    "@nexusdesk/types": "*",
    "@nexusdesk/utils": "*",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
