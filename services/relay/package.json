{
  "name": "@nexusdesk/relay",
  "version": "0.1.0",
  "description": "TURN REST credential service and coturn config generator for NexusDesk",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "nexusdesk-relay": "./dist/main.js"
  },
  "files": ["dist", "coturn.conf.template"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "generate-coturn-config": "node dist/generate-config.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "node -e \"console.log('no tests yet')\""
  },
  "dependencies": {
    "@nexusdesk/types": "*",
    "@nexusdesk/utils": "*",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
